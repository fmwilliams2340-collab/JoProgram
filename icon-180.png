{
  "monday": {
    "title": "Monday",
    "subtitle": "Upper Body",
    "focus": "Strength, posture, and upper-body muscle",
    "warmup": [
      "5 minutes treadmill walk or easy row",
      "Shoulder circles x 10 each way",
      "Light machine chest press x 12",
      "Light supported row x 12"
    ],
    "cooldown": [
      "10 minutes treadmill walk or Concept2 row"
    ],
    "exercises": [
      {
        "id": "plate_chest_press",
        "name": "Plate Loaded Chest Press",
        "sets": 3,
        "repRange": "10-12",
        "type": "Upper",
        "tip": "Keep shoulder blades back. Smooth reps beat heavy reps.",
        "mistakes": [
          "Letting shoulders roll forward",
          "Bouncing the handles",
          "Locking elbows hard"
        ],
        "alternatives": [
          "Machine chest press",
          "Smith machine bench press",
          "Dumbbell bench press"
        ],
        "cues": [
          "Set seat so handles meet mid-chest",
          "Press under control",
          "Stop 1-2 reps before form breaks"
        ]
      },
      {
        "id": "chest_supported_row",
        "name": "Chest-Supported Row",
        "sets": 3,
        "repRange": "10-12",
        "type": "Upper",
        "tip": "Pull with the elbows, not the hands.",
        "mistakes": [
          "Shrugging shoulders",
          "Jerking the weight",
          "Lifting chest off pad"
        ],
        "alternatives": [
          "Seated row machine",
          "One-arm dumbbell row",
          "Cable row if available"
        ],
        "cues": [
          "Chest stays on pad",
          "Pause briefly at the squeeze",
          "Lower slowly"
        ]
      },
      {
        "id": "lat_pulldown",
        "name": "Lat Pulldown",
        "sets": 3,
        "repRange": "10-12",
        "type": "Upper",
        "tip": "Think chest tall and elbows down.",
        "mistakes": [
          "Pulling behind the neck",
          "Rocking backward",
          "Using too much weight"
        ],
        "alternatives": [
          "Assisted pullup machine",
          "Neutral-grip pulldown",
          "Machine high row"
        ],
        "cues": [
          "Grip just outside shoulders",
          "Pull bar to upper chest",
          "Control the return"
        ]
      },
      {
        "id": "machine_shoulder_press",
        "name": "Machine Shoulder Press",
        "sets": 2,
        "repRange": "10-12",
        "type": "Upper",
        "tip": "Use a pain-free range and keep it controlled.",
        "mistakes": [
          "Arching low back",
          "Pressing through pain",
          "Dropping too fast"
        ],
        "alternatives": [
          "Seated dumbbell press",
          "Landmine press",
          "Incline press machine"
        ],
        "cues": [
          "Brace gently",
          "Press smoothly",
          "Stop short of painful range"
        ]
      },
      {
        "id": "machine_curl",
        "name": "Machine Biceps Curl",
        "sets": 2,
        "repRange": "10-12",
        "type": "Accessory",
        "tip": "Slow reps make light weight productive.",
        "mistakes": [
          "Swinging",
          "Letting elbows drift",
          "Dropping weight"
        ],
        "alternatives": [
          "Dumbbell curl",
          "Cable curl",
          "EZ-bar curl"
        ],
        "cues": [
          "Elbows planted",
          "Curl and squeeze",
          "Lower under control"
        ]
      },
      {
        "id": "triceps_pressdown",
        "name": "Triceps Pressdown",
        "sets": 2,
        "repRange": "10-12",
        "type": "Accessory",
        "tip": "Keep elbows pinned and finish the rep.",
        "mistakes": [
          "Moving shoulders",
          "Leaning too far",
          "Snapping elbows"
        ],
        "alternatives": [
          "Machine triceps extension",
          "Overhead rope extension",
          "Close-grip press machine"
        ],
        "cues": [
          "Elbows by ribs",
          "Press down to full extension",
          "Return slowly"
        ]
      }
    ]
  },
  "tuesday": {
    "title": "Tuesday",
    "subtitle": "Lower Body - Knee Friendly",
    "focus": "Leg strength, glutes, and knee-smart movement",
    "warmup": [
      "5 minutes treadmill walk",
      "Sit-to-stand x 10",
      "Heel raises x 15",
      "Mini squats x 10 to comfortable depth"
    ],
    "cooldown": [
      "10 minutes treadmill walk or easy row"
    ],
    "exercises": [
      {
        "id": "leg_press",
        "name": "Leg Press",
        "sets": 3,
        "repRange": "10-12",
        "type": "Lower",
        "tip": "Pain-free range. Do not chase depth.",
        "mistakes": [
          "Letting knees cave in",
          "Going too deep for the knee",
          "Locking knees hard"
        ],
        "alternatives": [
          "Hack squat machine",
          "Box squat to bench",
          "TRX assisted squat"
        ],
        "cues": [
          "Feet shoulder-width",
          "Knees track over toes",
          "Move slowly and smoothly"
        ]
      },
      {
        "id": "db_rdl",
        "name": "Dumbbell Romanian Deadlift",
        "sets": 3,
        "repRange": "10-12",
        "type": "Lower",
        "tip": "Hips back, spine tall, slight knee bend.",
        "mistakes": [
          "Rounding the back",
          "Squatting instead of hinging",
          "Letting weights drift forward"
        ],
        "alternatives": [
          "Smith machine RDL",
          "Machine back extension",
          "Hip hinge with dowel"
        ],
        "cues": [
          "Soft knees",
          "Push hips back",
          "Feel hamstrings load"
        ]
      },
      {
        "id": "hip_thrust",
        "name": "Machine or Bench Hip Thrust",
        "sets": 3,
        "repRange": "10-12",
        "type": "Lower",
        "tip": "Glutes do the work, not the low back.",
        "mistakes": [
          "Overarching at top",
          "Feet too far away",
          "Rushing reps"
        ],
        "alternatives": [
          "Glute bridge machine",
          "Floor glute bridge",
          "Cable pull-through if available"
        ],
        "cues": [
          "Chin tucked",
          "Drive through heels",
          "Pause at top"
        ]
      },
      {
        "id": "seated_leg_curl",
        "name": "Seated Leg Curl",
        "sets": 3,
        "repRange": "10-12",
        "type": "Lower",
        "tip": "Hamstrings support the knee. Control matters.",
        "mistakes": [
          "Lifting hips",
          "Bouncing reps",
          "Too much weight"
        ],
        "alternatives": [
          "Lying leg curl",
          "Standing leg curl",
          "Stability ball curl"
        ],
        "cues": [
          "Back against pad",
          "Curl smoothly",
          "Slow return"
        ]
      },
      {
        "id": "leg_extension",
        "name": "Leg Extension",
        "sets": 2,
        "repRange": "12-15",
        "type": "Lower",
        "tip": "Light and controlled. Stop if knee pain rises.",
        "mistakes": [
          "Going too heavy",
          "Snapping into lockout",
          "Using painful range"
        ],
        "alternatives": [
          "Short arc quad",
          "Supported sit-to-stand",
          "Terminal knee extension as warmup only"
        ],
        "cues": [
          "Light load",
          "Controlled lift",
          "Use comfortable range"
        ]
      },
      {
        "id": "calf_raise",
        "name": "Standing or Seated Calf Raise",
        "sets": 3,
        "repRange": "12-15",
        "type": "Accessory",
        "tip": "Full stretch and full squeeze.",
        "mistakes": [
          "Bouncing",
          "Rushing",
          "Partial reps"
        ],
        "alternatives": [
          "Leg press calf raise",
          "Seated calf raise",
          "Bodyweight calf raise"
        ],
        "cues": [
          "Pause at top",
          "Lower slowly",
          "Hold support if standing"
        ]
      }
    ]
  },
  "thursday": {
    "title": "Thursday",
    "subtitle": "Full Body",
    "focus": "Balanced strength and endurance",
    "warmup": [
      "5 minutes treadmill walk or easy row",
      "Light leg press x 10",
      "Light chest press x 10",
      "Easy row x 10"
    ],
    "cooldown": [
      "10-15 minutes treadmill walk or Concept2 row"
    ],
    "exercises": [
      {
        "id": "hack_squat_or_leg_press",
        "name": "Hack Squat Machine or Leg Press",
        "sets": 3,
        "repRange": "10-12",
        "type": "Lower",
        "tip": "Choose the machine that feels best on the knee.",
        "mistakes": [
          "Going too deep",
          "Knees caving in",
          "Rushing reps"
        ],
        "alternatives": [
          "Box squat",
          "TRX assisted squat",
          "Leg press"
        ],
        "cues": [
          "Controlled depth",
          "Push through full foot",
          "Stay pain-free"
        ]
      },
      {
        "id": "machine_chest_press",
        "name": "Machine Chest Press",
        "sets": 3,
        "repRange": "10-12",
        "type": "Upper",
        "tip": "Stable machine work builds confidence.",
        "mistakes": [
          "Shoulders forward",
          "Uneven press",
          "Bouncing"
        ],
        "alternatives": [
          "Plate-loaded chest press",
          "Incline chest press",
          "Dumbbell bench"
        ],
        "cues": [
          "Chest tall",
          "Press evenly",
          "Slow return"
        ]
      },
      {
        "id": "machine_row",
        "name": "Machine Row",
        "sets": 3,
        "repRange": "10-12",
        "type": "Upper",
        "tip": "Posture first, load second.",
        "mistakes": [
          "Shrugging",
          "Using momentum",
          "Short reps"
        ],
        "alternatives": [
          "Chest-supported row",
          "Seated cable row",
          "One-arm dumbbell row"
        ],
        "cues": [
          "Elbows back",
          "Squeeze shoulder blades",
          "Lower slowly"
        ]
      },
      {
        "id": "seated_leg_curl_thu",
        "name": "Seated Leg Curl",
        "sets": 2,
        "repRange": "12-15",
        "type": "Lower",
        "tip": "A little extra hamstring work supports the knee.",
        "mistakes": [
          "Too heavy",
          "Fast reps",
          "Hips lifting"
        ],
        "alternatives": [
          "Lying curl",
          "Standing curl",
          "Light RDL"
        ],
        "cues": [
          "Smooth curl",
          "Pause briefly",
          "Slow return"
        ]
      },
      {
        "id": "lat_pulldown_thu",
        "name": "Lat Pulldown",
        "sets": 2,
        "repRange": "10-12",
        "type": "Upper",
        "tip": "Keep ribs down and chest tall.",
        "mistakes": [
          "Swinging",
          "Pulling behind neck",
          "Shrugging"
        ],
        "alternatives": [
          "Assisted pullup",
          "High row machine",
          "Neutral pulldown"
        ],
        "cues": [
          "Elbows down",
          "Upper chest target",
          "Controlled return"
        ]
      }
    ]
  },
  "friday": {
    "title": "Friday",
    "subtitle": "Accessory and Finisher",
    "focus": "Chest, shoulders, arms, calves, and posture",
    "warmup": [
      "5 minutes treadmill walk",
      "Shoulder circles x 10",
      "Band pull-aparts or light reverse fly x 12",
      "Light chest press x 10"
    ],
    "cooldown": [
      "10 minutes treadmill walk or Concept2 row"
    ],
    "exercises": [
      {
        "id": "incline_chest_press",
        "name": "Incline Plate-Loaded Chest Press",
        "sets": 3,
        "repRange": "10-12",
        "type": "Upper",
        "tip": "Great second chest day without overcomplicating it.",
        "mistakes": [
          "Seat too low",
          "Elbows flared too high",
          "Rushing the negative"
        ],
        "alternatives": [
          "Machine chest press",
          "Dumbbell incline press",
          "Smith incline press"
        ],
        "cues": [
          "Handles at upper chest",
          "Press up and slightly in",
          "Lower slow"
        ]
      },
      {
        "id": "lawnmower_rows",
        "name": "Single-Arm Dumbbell Row - Lawnmower Starts",
        "sets": 3,
        "repRange": "10-12 each side",
        "type": "Upper",
        "tip": "Use the bench for support. Stable beats fancy.",
        "mistakes": [
          "Twisting too much",
          "Yanking the dumbbell",
          "Rounding back"
        ],
        "alternatives": [
          "Chest-supported row",
          "Machine row",
          "Seated row"
        ],
        "cues": [
          "One hand on bench",
          "Pull elbow toward hip",
          "Control the lower"
        ]
      },
      {
        "id": "machine_lateral_raise",
        "name": "Machine Lateral Raise",
        "sets": 3,
        "repRange": "12-15",
        "type": "Accessory",
        "tip": "Keep it light and smooth for shoulder health.",
        "mistakes": [
          "Shrugging",
          "Going too heavy",
          "Swinging"
        ],
        "alternatives": [
          "Seated dumbbell lateral raise",
          "Cable lateral raise",
          "Lean-away raise"
        ],
        "cues": [
          "Lead with elbows",
          "Stop at shoulder height",
          "Slow return"
        ]
      },
      {
        "id": "machine_biceps_curl_fri",
        "name": "Machine or Cable Biceps Curl",
        "sets": 3,
        "repRange": "10-12",
        "type": "Accessory",
        "tip": "Controlled curls protect the elbows and build the arms.",
        "mistakes": [
          "Swinging",
          "Rushing",
          "Short reps"
        ],
        "alternatives": [
          "Dumbbell curl",
          "EZ-bar curl",
          "Hammer curl"
        ],
        "cues": [
          "Elbows steady",
          "Curl fully",
          "Lower slowly"
        ]
      },
      {
        "id": "rope_pressdown_fri",
        "name": "Rope Triceps Pressdown",
        "sets": 3,
        "repRange": "10-12",
        "type": "Accessory",
        "tip": "Finish strong, elbows still.",
        "mistakes": [
          "Shoulders moving",
          "Too much body lean",
          "Snapping elbows"
        ],
        "alternatives": [
          "Machine triceps press",
          "Cable bar pressdown",
          "Bench dip only if shoulders tolerate"
        ],
        "cues": [
          "Elbows tucked",
          "Separate rope at bottom",
          "Slow return"
        ]
      },
      {
        "id": "calf_raise_fri",
        "name": "Standing Calf Raise Machine",
        "sets": 3,
        "repRange": "12-15",
        "type": "Accessory",
        "tip": "One calf movement is enough. Make it count.",
        "mistakes": [
          "Bouncing",
          "Half reps",
          "No pause"
        ],
        "alternatives": [
          "Seated calf raise",
          "Leg press calf raise",
          "Bodyweight calf raise"
        ],
        "cues": [
          "Pause high",
          "Deep stretch",
          "Controlled tempo"
        ]
      }
    ]
  }
}